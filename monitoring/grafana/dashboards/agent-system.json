{
  "title": "🧠 Agent System Dashboard",
  "version": 1,
  "panels": [
    {
      "title": "Agent Health",
      "type": "stat",
      "datasource": "Prometheus",
      "targets": [{ "expr": "up{job=\"agent-api\"}" }]
    },
    {
      "title": "Task Processing Rate",
      "type": "graph",
      "datasource": "Prometheus",
      "targets": [{ "expr": "rate(agent_tasks_processed_total[5m])" }]
    },
    {
      "title": "Error Rate",
      "type": "graph",
      "datasource": "Prometheus",
      "targets": [{ "expr": "rate(agent_tasks_failed_total[5m])" }]
    },
    {
      "title": "Memory Usage",
      "type": "gauge",
      "datasource": "Prometheus",
      "targets": [{ "expr": "process_resident_memory_bytes" }]
    }
  ],
  "time": { "from": "now-6h", "to": "now" }
}
