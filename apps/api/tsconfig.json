{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "paths": {
      "@/*": ["./src/*"],
      "@/db/*": ["../../packages/db/*"],
      "@/shared/*": ["../../packages/shared/*"]
    }
  },
  "include": ["src/**/*", "../../packages/db/**/*", "../../packages/shared/**/*"],
  "exclude": ["node_modules", "dist"]
}
