# =========================================================
# NOVASHOP ENVIRONMENT VARIABLES — COPY TO .env.local
# =========================================================
# Đừng commit file này nếu chứa key thật. Chỉ dùng .env.example để tham khảo.

# =====================================
# 1. CLERK AUTH (Đăng nhập/Đăng ký)
# =====================================
# Lấy từ: https://dashboard.clerk.com/ → Configure → API keys → Production
# Production key bắt đầu bằng pk_live_
VITE_CLERK_PUBLISHABLE_KEY=pk_live_xxx
# Backend Secret Key (không có VITE_ prefix)
CLERK_SECRET_KEY=sk_live_xxx

# =====================================
# 2. FIREBASE (Database + Storage)
# =====================================
# Lấy từ: https://console.firebase.google.com/ → Project Settings → General
VITE_FIREBASE_API_KEY=AIzaSyxxx
VITE_FIREBASE_AUTH_DOMAIN=xxx.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=xxx
VITE_FIREBASE_STORAGE_BUCKET=xxx.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=xxx
VITE_FIREBASE_APP_ID=1:xxx
# Firebase Admin Service Account JSON (backend only)
FIREBASE_SERVICE_ACCOUNT_JSON={}

# =====================================
# 3. STRIPE (Thanh toán thẻ)
# =====================================
# Publishable key cho frontend (test: pk_test_, live: pk_live_)
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_xxx
# Secret key CHỈ dùng trên server (test: sk_test_, live: sk_live_)
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# URL frontend sau khi thanh toán
CLIENT_URL=https://trong-dinh-store.netlify.app

# =====================================
# 4. BACKEND API
# =====================================
# URL backend (để trống nếu frontend và backend cùng domain)
VITE_API_URL=
# URL public của backend (cho webhook callbacks)
PUBLIC_API_URL=https://xxx.onrender.com

# =====================================
# 5. SHOP INFO
# =====================================
VITE_SHOP_NAME=TRỌNG ĐỊNH STORE
VITE_SHOP_PHONE=0369712958
VITE_SHOP_EMAIL=tutrantuan988@gmail.com
VITE_SHOP_DOMAIN=trong-dinh-store.netlify.app
VITE_SHOP_ADDRESS=Hà Nội, Việt Nam
VITE_SHOP_FACEBOOK=https://facebook.com/xxx
VITE_SHOP_INSTAGRAM=
VITE_SHOP_TIKTOK=@nclonf

# =====================================
# 6. ADMIN & EMAIL
# =====================================
VITE_ADMIN_EMAILS=tutrantuan988@gmail.com
ADMIN_API_TOKEN=random_string_at_least_32_chars
RESEND_API_KEY=re_xxx
EMAIL_FROM=TRỌNG ĐỊNH STORE <tutrantuan988@gmail.com>

# =====================================
# 7. SOCIAL MEDIA LINKS
# =====================================
# Zalo Official Account — https://oa.zalo.me/
VITE_SHOP_ZALO=
# TikTok
VITE_SHOP_TIKTOK=
# YouTube
VITE_SHOP_YOUTUBE=

# =====================================
# 8. TRACKING & ANALYTICS
# =====================================
# Google Tag Manager container ID (VD: GTM-XXXXXXX)
# Nếu có GTM thì GA4 sẽ load qua GTM, không cần VITE_GA_ID riêng
VITE_GTM_ID=
# Google Analytics 4 Measurement ID (VD: G-XXXXXXXXXX)
VITE_GA_ID=
# Facebook Pixel ID (VD: 123456789012345)
# Lấy từ: https://business.facebook.com/ → Events Manager → Pixels
VITE_FACEBOOK_PIXEL_ID=

# =====================================
# 9. THIRD-PARTY SERVICES
# =====================================
# Google reCAPTCHA v3 — https://www.google.com/recaptcha/admin
# VITE_RECAPTCHA_SITE_KEY: Site Key (public, dùng cho frontend)
# RECAPTCHA_SECRET_KEY: Secret Key (CHỈ dùng backend, không prefix VITE_)
# Bảo vệ form liên hệ/đăng ký khỏi spam
VITE_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
# Cloudinary (image upload)
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=
# Sentry error monitoring
VITE_SENTRY_DSN=
VITE_SENTRY_TRACES_SAMPLE_RATE=0.05
# AI Chat (Groq) — lấy tại https://console.groq.com/
GROQ_API_KEY=gsk_...

# Tawk.to Live Chat — Site ID từ https://dashboard.tawk.to/
VITE_TAWKTO_ID=

# =====================================
# 10. POSTGRESQL DATABASE (Commerce Core Refactor)
# =====================================
# PostgreSQL connection string for new commerce core
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://novashop_user:novashop_password_dev@localhost:5432/novashop_db
# Connection pool settings
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
# Feature flags for gradual migration
USE_POSTGRES_PRODUCTS=false
USE_POSTGRES_READS=false
USE_POSTGRES_CATEGORIES=false

# =====================================
# 11. REDIS CACHE (Phase 4)
# =====================================
# Redis connection for caching
REDIS_URL=redis://localhost:6379
REDIS_CACHE_TTL_PRODUCTS=3600
REDIS_CACHE_TTL_CATEGORIES=86400
REDIS_CACHE_TTL_INVENTORY=300
