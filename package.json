  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "start": "node server/index.js",
    "server": "node server/index.js",
    "check:env:old": "node server/check-env.js",
    "seed": "node server/seed.js",
    "seed:firestore": "node server/seed.js",
    "seed:mongo": "node server/seed-mongodb.js",
    "seed:postgres": "node scripts/seed-postgres.js",
