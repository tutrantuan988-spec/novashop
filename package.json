    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report e2e/report",
    "import:products": "node server/utils/productImport.js",
    "import:template": "node server/utils/productImport.js --generate-template",
    "redis:check": "node -e \"require('./server/services/redis').getRedis().then(r => console.log('Redis OK:', r ? 'Connected' : 'Fallback')).catch(e => console.log('Redis Error:', e.message))\"",
    "check": "node agents/build-agent.js",
    "check:quick": "node agents/build-agent.js --quick",
    "check:env": "node scripts/check-env.js",
    "debug": "node scripts/debug-workflow.js --init",
    "debug:list": "node scripts/debug-workflow.js --list",
    "setup:hooks": "bash .hooks/setup-hooks.sh",
    "setup:all": "node scripts/setup.js",
    "server:import": "node server/routes/import.js",
    "deploy:check": "node scripts/deploy-production.js",
    "deploy:production": "npm run build && npm run deploy:check",
    "deploy:auto": "node scripts/auto-deploy.bat",
    "recovery": "node scripts/session-recovery.js",
    "validate": "node scripts/deploy-production.js",
    "go": "npm run recovery && npm run dev"
  },
