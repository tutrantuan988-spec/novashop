#!/bin/sh
# ============================================
# Post-commit Hook — TRỌNG ĐỊNH STORE
# Pattern from everything-claude-code
# Ghi log commit và kiểm tra build status
# ============================================

COMMIT_MSG=$(git log -1 --pretty=%B)
COMMIT_HASH=$(git log -1 --pretty=%h)
COMMIT_DATE=$(git log -1 --pretty=%cd --date=short)

echo "✅ [post-commit] Commit $COMMIT_HASH thành công!"
echo "   📝 $COMMIT_MSG"
echo "   🗓️  $COMMIT_DATE"

# Ghi commit log
echo "$COMMIT_DATE | $COMMIT_HASH | $COMMIT_MSG" >> .git-commit-log 2>/dev/null || true

# Gợi ý push
BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null)
echo ""
echo "💡 Muốn push lên $BRANCH? Chạy: git push origin $BRANCH"
echo ""
