# =========================================================
# BACKEND-ONLY (không có VITE_ prefix)
# =========================================================

# ===== Admin verify token (P10) =====
# Cần thiết cho production. Đặt giá trị random dài.
ADMIN_API_TOKEN=novashop_admin_change_me

# ===== Guest checkout token (P4) =====
# Secret để sign HMAC guest token. Khác ADMIN_API_TOKEN càng tốt.
GUEST_TOKEN_SECRET=novashop_guest_change_me

# ===== Stripe backend (P3, P7) =====
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ===== Firebase Admin (P3, P7, P12, P13, P15) =====
# JSON 1 dòng từ service account, hoặc dùng GOOGLE_APPLICATION_CREDENTIALS
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_PROJECT_ID=trantuantu-fa889

# ===== Resend email (P6, P12) =====
RESEND_API_KEY=
EMAIL_FROM=NovaShop <onboarding@resend.dev>
ADMIN_NOTIFICATION_EMAIL=tutrantuan988@gmail.com
CLIENT_URL=http://localhost:5173

# ===== Algolia Search (P8) =====
# Free 10k records/10k ops month. Bỏ trống để fallback Firestore search.
ALGOLIA_APP_ID=
ALGOLIA_ADMIN_API_KEY=
ALGOLIA_INDEX_NAME=products
# Frontend: dùng SEARCH-ONLY key (không phải ADMIN)
VITE_ALGOLIA_APP_ID=
VITE_ALGOLIA_SEARCH_KEY=
VITE_ALGOLIA_INDEX_NAME=products

# ===== Cloudinary image optimization (P9) =====
# Free 25 credits/month. Bỏ trống → upload sẽ fail.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ===== GHN Shipping (P14) =====
# Sandbox: https://api-sandbox.ghn.dev/shiip/public-api
# Production: https://online-gateway.ghn.vn/shiip/public-api
GHN_API_TOKEN=
GHN_SHOP_ID=
GHN_API_URL=https://online-gateway.ghn.vn/shiip/public-api

# ===== Sentry monitoring (P11) =====
# Free 5k errors/month
SENTRY_DSN=
VITE_SENTRY_DSN=
VITE_SENTRY_TRACES_SAMPLE_RATE=0.05

# ===== Abandoned Cart (P6) =====
ABANDONED_COUPON_CODE=COMEBACK5

# ===== Misc =====
NODE_ENV=development
PORT=3001
# Set "1" để disable rate limit khi dev
DISABLE_RATE_LIMIT=
