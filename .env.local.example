# =========================================================
# NOVASHOP ENVIRONMENT VARIABLES — COPY TO .env.local
# =========================================================
# Đừng commit file này nếu chứa key thật. Chỉ dùng .env.example để tham khảo.

# =====================================
# 1. CLERK AUTH (Đăng nhập/Đăng ký)
# =====================================
VITE_CLERK_PUBLISHABLE_KEY=pk_live_xxx
CLERK_SECRET_KEY=sk_live_xxx

# =====================================
# 2. FIREBASE (Database + Storage)
# =====================================
VITE_FIREBASE_API_KEY=AIzaSyxxx
VITE_FIREBASE_AUTH_DOMAIN=xxx.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=xxx
VITE_FIREBASE_STORAGE_BUCKET=xxx.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=xxx
VITE_FIREBASE_APP_ID=1:xxx
FIREBASE_SERVICE_ACCOUNT_JSON={}

# =====================================
# 3. VNPAY (Thanh toán online - Việt Nam)
# =====================================
VNP_TMN_CODE=your_vnpay_tmn_code
VNP_HASH_SECRET=your_vnpay_hash_secret
VNP_URL=https://pay.vnpay.vn/vpcpay.html
CLIENT_URL=https://trong-dinh-store.netlify.app

# =====================================
# 3b. STRIPE (Thẻ quốc tế - optional)
# =====================================
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_xxx
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# =====================================
# 4. BACKEND API
# =====================================
VITE_API_URL=
PUBLIC_API_URL=https://xxx.onrender.com

# =====================================
# 5. SHOP INFO
# =====================================
VITE_SHOP_NAME=TRỌNG ĐỊNH STORE
VITE_SHOP_PHONE=0369712958
VITE_SHOP_EMAIL=tutrantuan988@gmail.com
VITE_SHOP_DOMAIN=trong-dinh-store.netlify.app
VITE_SHOP_ADDRESS=Hà Nội, Việt Nam
VITE_SHOP_FACEBOOK=https://facebook.com/xxx
VITE_SHOP_INSTAGRAM=
VITE_SHOP_TIKTOK=@nclonf

# =====================================
# 6. ADMIN & EMAIL
# =====================================
VITE_ADMIN_EMAILS=tutrantuan988@gmail.com
ADMIN_API_TOKEN=random_string_at_least_32_chars
RESEND_API_KEY=re_xxx
EMAIL_FROM=TRỌNG ĐỊNH STORE <tutrantuan988@gmail.com>

# =====================================
# 7. OPTIONAL (bỏ trống nếu không dùng)
# =====================================
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
