# NovaShop production environment
# Copy các biến này lên hosting provider, KHÔNG commit secret thật lên GitHub.

# ===================== Shop Info =====================
VITE_SHOP_NAME=NovaShop
VITE_SHOP_DOMAIN=novashop.vn
VITE_SHOP_PHONE=1900 1234
VITE_SHOP_EMAIL=support@novashop.vn
VITE_SHOP_ADDRESS=123 Nguyễn Huệ, Q.1, TP.HCM
VITE_SHOP_FACEBOOK=https://facebook.com/novashop
VITE_SHOP_INSTAGRAM=https://instagram.com/novashop
VITE_SHOP_YOUTUBE=https://youtube.com/novashop
VITE_SHOP_DESCRIPTION=NovaShop - Mua sắm online thông minh với hàng nghìn sản phẩm chính hãng, giao nhanh 24h.

# Clerk Authentication (bắt buộc production)
VITE_CLERK_PUBLISHABLE_KEY=pk_live_...

# Firebase (lấy từ Firebase Console -> Project Settings -> General)
VITE_FIREBASE_API_KEY=AIza...
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef

# Stripe (lấy từ Stripe Dashboard -> Developers -> API keys)
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Backend API URL (frontend gọi đến)
VITE_API_URL=https://your-domain.com

# Admin emails (phân cách bằng dấu phẩy)
VITE_ADMIN_EMAILS=admin@novashop.vn

# Upload (Cloudinary)
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=novashop_unsigned

# ===================== Backend private keys =====================
# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Firebase Admin service account JSON path trên server
GOOGLE_APPLICATION_CREDENTIALS=/etc/secrets/firebase-admin.json

# URLs
CLIENT_URL=https://your-domain.com
PORT=3001
PUBLIC_API_URL=https://your-domain.com

# Admin
ADMIN_EMAILS=admin@your-domain.com
ADMIN_API_TOKEN=sinh_ngau_nhien_32_ky_tu
ADMIN_NOTIFICATION_EMAIL=admin@your-domain.com

# Email đơn hàng bằng Resend (tuỳ chọn)
RESEND_API_KEY=re_...
EMAIL_FROM=NovaShop <orders@your-domain.com>

# VNPay sandbox
VNP_TMN_CODE=
VNP_HASH_SECRET=
VNP_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html

# MoMo test
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create
