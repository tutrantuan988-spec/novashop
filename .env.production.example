# NovaShop Production Environment Variables
# Copy this file to .env.production and fill in the values

# =========================
# Server
# =========================
NODE_ENV=production
PORT=3001
HOST=0.0.0.0

# =========================
# PostgreSQL
# =========================
DATABASE_URL=postgresql://user:password@localhost:5432/novashop_db
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=novashop_db
PG_USER=novashop_user
PG_PASSWORD=your_secure_password_here

# Feature flags
USE_POSTGRES_CATEGORIES=true
USE_POSTGRES_PRODUCTS=true
USE_POSTGRES_READS=true

# =========================
# Redis
# =========================
REDIS_URL=redis://localhost:6379

# =========================
# JWT Authentication
# =========================
JWT_SECRET=your-super-secret-jwt-key-at-least-32-characters
JWT_EXPIRES_IN=7d

# =========================
# Admin
# =========================
ADMIN_EMAILS=admin@yourdomain.com
ADMIN_API_TOKEN=your-admin-api-token-at-least-32-characters

# =========================
# Cloudinary (Image Upload)
# =========================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Frontend Cloudinary (public only)
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_upload_preset

# =========================
# Site Configuration
# =========================
SITE_URL=https://yourdomain.com
SITE_NAME=NovaShop

# =========================
# Payment (optional)
# =========================
VNPAY_TMN_CODE=your_tmn_code
VNPAY_HASH_SECRET=your_hash_secret
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=https://yourdomain.com/thanh-toan/vnpay-return

# =========================
# Email (optional)
# =========================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# =========================
# Monitoring (optional)
# =========================
SENTRY_DSN=https://your_sentry_dsn
