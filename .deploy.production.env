# Deploy Configuration for Production
# Copy this to .deploy.production.env and fill in your values

# Server configuration
SERVER_USER=root
SERVER_HOST=your-server-ip-here
DOMAIN=yourdomain.com

# Optional: Git branch to deploy
GIT_BRANCH=main

# Optional: Docker registry (if using private registry)
# DOCKER_REGISTRY=registry.digitalocean.com
# DOCKER_IMAGE=novashop
